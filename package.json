{
  "name": "edugrid",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node scripts/clean-next.js",
    "dev": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint \"src/**/*.{js,jsx,ts,tsx}\" --max-warnings 50",
    "payload": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts payload",
    "generate:types": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts payload generate:types",
    "generate:importmap": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts payload generate:importmap",
    "migrate": "cross-env PAYLOAD_CONFIG_PATH=payload.config.ts payload migrate",
    "migrate:create": "cross-env PAYLOAD_CONFIG_PATH=payload.config.ts payload migrate:create",
    "migrate:status": "cross-env PAYLOAD_CONFIG_PATH=payload.config.ts payload migrate:status",
    "test": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts jest --runInBand --forceExit",
    "test:register:http": "node scripts/test-register-http.js",
    "test:db": "node test-db-connection.js",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "seed": "node scripts/seed-test-data.js"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "3.78.0",
    "@payloadcms/richtext-slate": "3.78.0",
    "@payloadcms/ui": "3.78.0",
    "@supabase/supabase-js": "^2.49.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "dotenv": "^16.3.1",
    "jose": "^6.1.3",
    "lucide-react": "^1.20.0",
    "next": "16.2.1",
    "payload": "3.78.0",
    "pdf-parse": "1.1.1",
    "pdfjs-dist": "^5.4.530",
    "pg": "^8.11.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sass": "^1.97.3",
    "tesseract.js": "^7.0.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.16",
    "cross-env": "^7.0.3",
    "eslint": "^8.55.0",
    "eslint-config-next": "^14.0.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
